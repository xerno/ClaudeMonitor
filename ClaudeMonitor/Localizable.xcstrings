          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ID organizace musí být platné UUID (např. xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Organisations-id skal være et gyldigt UUID (f.eks. xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)."
          }
        },
        "de" : {
          "stringUnit" : {
